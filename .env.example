# ==================== 数据库配置 ====================
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=change-me
MYSQL_DB=eam_ai

# ==================== Milvus 向量数据库 ====================
MILVUS_HOST=localhost
MILVUS_PORT=19530
MILVUS_DEFAULT_ALIAS=default
MILVUS_DEFAULT_DB=AI_EAM
MILVUS_COLLECTION_KNOWLEDGE=equipment_knowledge
MILVUS_COLLECTION_CASES=fault_cases

# ==================== MinIO 对象存储 ====================
MINIO_ENDPOINT=127.0.0.1:9100
MINIO_ACCESS_KEY=change-me
MINIO_SECRET_KEY=change-me
MINIO_BUCKET=vanna-training-data
KB_BUCKET_NAME=knowledge-base

# ==================== AI 模型配置 ====================
AI_API_KEY=
AI_BASE_URL="https://api.deepseek.com/v1"
AI_MODEL="deepseek-v4-flash"
SILICON_FLOW_API_KEY=
SILICON_FLOW_EMBEDDING_MODEL=Qwen/Qwen3-VL-Embedding-8B
EMBEDDING_STRATEGY=siliconflow
EMBEDDING_DIM=4096
DEEPSEEK_API_KEY=

# ==================== JWT 配置 ====================
JWT_SECRET_KEY=replace-with-a-long-random-secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# ==================== 应用配置 ====================
APP_NAME=AI-EAM
APP_VERSION=1.0.0
DEBUG=false
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:8000,http://127.0.0.1:8000
